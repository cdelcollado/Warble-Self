# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=warble
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=change_me
POSTGRES_DB=warble

# ── Domain & SSL ──────────────────────────────────────────────────────────────
# Set to your domain (e.g. warble.example.com) for automatic HTTPS via Let's Encrypt.
# Use "localhost" for local development (HTTP only).
DOMAIN=localhost

# ── Better Auth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change_me_min_32_chars
# Must match your domain. Use https:// in production.
BETTER_AUTH_URL=http://localhost

# ── MinIO ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 8
MINIO_ACCESS_KEY=change_me
# Generate with: openssl rand -base64 32
MINIO_SECRET_KEY=change_me
MINIO_BUCKET=codefiles

# ── Admin API ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
ADMIN_SECRET=change_me

# ── Frontend ──────────────────────────────────────────────────────────────────
# Must match your domain. Use https:// in production.
FRONTEND_URL=http://localhost
